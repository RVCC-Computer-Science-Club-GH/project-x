# Environment Configuration
# Copy this file to .env.development and .env.production respectively

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_TIMEOUT=30000

# App Configuration
EXPO_PUBLIC_APP_NAME=Pathster
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_LOGGING=false
EXPO_PUBLIC_ENABLE_MOCK_DATA=false
