# Backend environment variables
# Copy to .env and update with local values

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database (MongoDB LTS)
# Format: mongodb://[username:password@]host[:port][/database][?options]
DATABASE_URL=mongodb://pathster_user:pathster_password_dev@localhost:27017/pathster_campus?authSource=admin

# API
API_CORS_ORIGIN=http://localhost:8081

# Authentication (JWT, OAuth, etc. - TBD)
# JWT_SECRET=your-secret-key-here
# OAUTH_GOOGLE_CLIENT_ID=xxx
# OAUTH_GOOGLE_CLIENT_SECRET=xxx
