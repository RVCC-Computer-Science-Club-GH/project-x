{
  "name": "@pathster/server",
  "version": "0.1.0",
  "private": true,
  "description": "Express microservice for Pathster backend API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@pathster/api-types": "*",
    "express": "^5.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^25.0.0",
    "@types/supertest": "^7.0.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "packageManager": "npm@11.0.0"
}
